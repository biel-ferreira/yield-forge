# Normalize line endings: store as LF, check out as LF on every platform so gofmt
# and tooling stay consistent (this file was lost previously, letting *.go drift to
# CRLF on Windows).
* text=auto eol=lf

# Source and config — always LF.
*.go    text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.sh    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf

# Windows-native scripts keep CRLF.
*.ps1   text eol=crlf
*.bat   text eol=crlf

# Binaries — never touch.
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
