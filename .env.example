# YieldForge — environment configuration.
#
# Copy this file to `.env` for local development:  cp .env.example .env
# Values in `.env` seed variables that are NOT already set in the real
# environment; real environment variables always take precedence.
# `.env` is git-ignored — never commit real secrets.

# Application environment: dev | staging | prod        (default: dev)
APP_ENV=dev

# HTTP listen port: 1..65535                           (default: 8080)
APP_PORT=8080

# Log level: debug | info | warn | error               (default: info; invalid -> info)
LOG_LEVEL=info

# Log format: json | text            (default: text when APP_ENV=dev, otherwise json)
LOG_FORMAT=text

# HTTP server timeouts (Go duration, e.g. 5s, 1m)
HTTP_READ_TIMEOUT=10s                 # default: 10s
HTTP_WRITE_TIMEOUT=10s                # default: 10s
HTTP_IDLE_TIMEOUT=60s                 # default: 60s

# Graceful shutdown budget (Go duration)               (default: 10s)
SHUTDOWN_TIMEOUT=10s

# ---- Database (SPEC-002) ----
# PostgreSQL connection string. REQUIRED — the app fails fast at startup if unset.
#   Local dev (Docker Postgres):  sslmode=disable
#   Hosted (Neon / Supabase / …): sslmode=require   (TLS in transit, PRD §10)
# Never commit a real DATABASE_URL — this file holds placeholders only.
# Host port 5433 matches the compose db mapping (chosen to avoid clashing with a
# native Postgres on 5432). Inside Docker the api uses db:5432 instead (see compose).
DATABASE_URL=postgres://yieldforge:yieldforge@localhost:5433/yieldforge_dev?sslmode=disable

# Connection pool tuning (optional; conservative defaults suit free-tier Postgres)
DB_MAX_OPEN_CONNS=10                   # default: 10
DB_MAX_IDLE_CONNS=5                    # default: 5
DB_CONN_MAX_LIFETIME=30m               # default: 30m
DB_CONN_MAX_IDLE_TIME=5m               # default: 5m
DB_CONNECT_TIMEOUT=5s                  # default: 5s  (bounded initial connect/ping)
