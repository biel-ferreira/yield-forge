# YieldForge — environment configuration.
#
# Copy this file to `.env` for local development:  cp .env.example .env
# Values in `.env` seed variables that are NOT already set in the real
# environment; real environment variables always take precedence.
# `.env` is git-ignored — never commit real secrets.

# Application environment: dev | staging | prod        (default: dev)
APP_ENV=dev

# HTTP listen port: 1..65535                           (default: 8080)
APP_PORT=8080

# Log level: debug | info | warn | error               (default: info; invalid -> info)
LOG_LEVEL=info

# Log format: json | text            (default: text when APP_ENV=dev, otherwise json)
LOG_FORMAT=text

# HTTP server timeouts (Go duration, e.g. 5s, 1m)
HTTP_READ_TIMEOUT=10s                 # default: 10s
HTTP_WRITE_TIMEOUT=10s                # default: 10s
HTTP_IDLE_TIMEOUT=60s                 # default: 60s

# Graceful shutdown budget (Go duration)               (default: 10s)
SHUTDOWN_TIMEOUT=10s

# ---- Database (SPEC-002) ----
# PostgreSQL connection string. REQUIRED — the app fails fast at startup if unset.
#   Local dev (Docker Postgres):  sslmode=disable
#   Hosted (Neon / Supabase / …): sslmode=require   (TLS in transit, PRD §10)
# Never commit a real DATABASE_URL — this file holds placeholders only.
# Host port 5433 matches the compose db mapping (chosen to avoid clashing with a
# native Postgres on 5432). Inside Docker the api uses db:5432 instead (see compose).
DATABASE_URL=postgres://yieldforge:yieldforge@localhost:5433/yieldforge_dev?sslmode=disable

# Connection pool tuning (optional; conservative defaults suit free-tier Postgres)
DB_MAX_OPEN_CONNS=10                   # default: 10
DB_MAX_IDLE_CONNS=5                    # default: 5
DB_CONN_MAX_LIFETIME=30m               # default: 30m
DB_CONN_MAX_IDLE_TIME=5m               # default: 5m
DB_CONNECT_TIMEOUT=5s                  # default: 5s  (bounded initial connect/ping)

# ---- Auth & sessions (SPEC-003) ----
# How long a login session stays valid (Go duration).        (default: 168h = 7 days)
SESSION_TTL=168h
# Name of the session cookie.                                 (default: yf_session)
AUTH_COOKIE_NAME=yf_session
# The cookie's Secure flag is derived from APP_ENV: on except when APP_ENV=dev
# (local dev uses plain HTTP). HttpOnly + SameSite are always set.

# ---- Observability / OpenTelemetry (SPEC-004) ----
# Telemetry is OFF by default and never required to run. Leaving the endpoint unset
# makes the whole OTel pipeline a no-op (the app behaves exactly as without it).
#
# Exporter: otlp | stdout | none   (default: otlp when an endpoint is set, else none)
# OTEL_EXPORTER_KIND=otlp
# OTLP endpoint of a collector / Jaeger / Grafana (enables export when set):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTLP headers — SECRET (e.g. backend API key). Never commit a real value:
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>
# Resource service.name:                                       (default: yield-forge)
OTEL_SERVICE_NAME=yield-forge
# Trace sampling probability 0.0..1.0 (1.0 = sample everything) (default: 1.0)
OTEL_TRACE_SAMPLE_RATIO=1.0

# Integration tests (optional). Point at a DISPOSABLE Postgres — the migration
# round-trip test applies and rolls back schema changes against it. Unset = the DB
# integration tests skip. The compose db works:
# TEST_DATABASE_URL=postgres://yieldforge:yieldforge@localhost:5433/yieldforge_dev?sslmode=disable
